DATABASE_URL="postgresql://user:password@localhost:5432/docforge"
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
GITHUB_ID="your-github-oauth-app-id"
GITHUB_SECRET="your-github-oauth-app-secret"
RESEND_API_KEY="re_..."
EMAIL_FROM="DocForge <noreply@yourdomain.com>"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_BUSINESS_PRICE_ID="price_..."

# Docker/production only — path to system Chromium
# PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium"

# PDF Storage (S3-compatible: AWS S3, Cloudflare R2, MinIO)
# STORAGE_BUCKET=docforge-pdfs
# STORAGE_REGION=auto
# STORAGE_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY_ID=xxx
# STORAGE_SECRET_ACCESS_KEY=xxx

# Sentry (optional — error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
